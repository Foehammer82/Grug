# Discord
DISCORD_TOKEN=your-discord-bot-token-here

# Comma-separated Discord user IDs that have full super-admin access to the web UI
# GRUG_SUPER_ADMIN_IDS=123456789012345678,987654321098765432

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-haiku-4-5
# More capable model used for character sheet parsing and history summarization
# ANTHROPIC_BIG_BRAIN_MODEL=claude-sonnet-4-6

# Postgres — credentials and DATABASE_URL are set directly in docker-compose.yml.
# Only set these here if you are running outside of Docker (e.g. local dev without compose).
# DATABASE_URL=postgresql+asyncpg://grug:grug@localhost:5432/grug

# General
DEFAULT_TIMEZONE=UTC

# Agent
AGENT_MAX_ITERATIONS=10
AGENT_CONTEXT_WINDOW=20
# How many overflow messages must accumulate before being summarised and archived to RAG
AGENT_HISTORY_ARCHIVE_BATCH=10
# Set to true to wipe conversation history on every restart (useful for prompt testing)
# FLUSH_CHAT_HISTORY=false
# Max number of per-channel history summaries kept in the vector store (oldest pruned beyond this)
AGENT_HISTORY_MAX_SUMMARIES=100
# How far back (in days) Grug reads history in guild channels (default: 30 days)
# AGENT_CONTEXT_LOOKBACK_DAYS=30

# Logging
LOG_LEVEL=INFO

# Caching — optional Redis or Valkey URL.
# When set, the shared cache uses Redis/Valkey instead of in-memory storage.
# Leave empty (or omit) to use the default in-memory cache.
# REDIS_URL=redis://localhost:6379/0

# MCP Servers (JSON array of server configs)
# MCP_SERVER_CONFIGS=[{"command": "npx", "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/files"]}]
MCP_SERVER_CONFIGS=[]

# Web UI / API
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback
WEB_SECRET_KEY=change-me-to-a-random-secret
WEB_CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# URL the browser uses to reach the API. Injected at container start (not baked into
# the JS bundle), so you can change it without rebuilding the web image.
# Defaults to http://localhost:8000 if unset.
# Set this to your public API URL when hosting on a VPS or behind a domain.
# VITE_API_URL=https://api.yourdomain.com

# Manager Agent — supervisor that reviews Grug's conversations and provides feedback
# MANAGER_REVIEW_ENABLED=false
# MANAGER_REVIEW_CRON=0 6 * * 1
# Discord webhook URL for manager reports (empty = disabled)
# MANAGER_WEBHOOK_URL=https://discord.com/api/webhooks/...
