# Discord
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_PREFIX=!

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Database
# Option A — SQLite (default, zero extra services needed):
DATABASE_URL=sqlite+aiosqlite:///./data/grug.db

# Option B — Postgres (pgvector replaces ChromaDB automatically when this is set):
# DATABASE_URL=postgresql+asyncpg://grug:grug@postgres:5432/grug
# POSTGRES_DB=grug
# POSTGRES_USER=grug
# POSTGRES_PASSWORD=change-me-in-production

# ChromaDB (only used when DATABASE_URL is SQLite — ignored for Postgres deployments)
CHROMA_PERSIST_DIR=./chroma_data

# Scheduler
SCHEDULER_TIMEZONE=UTC

# Agent
AGENT_MAX_ITERATIONS=10
AGENT_CONTEXT_WINDOW=20
# How many overflow messages must accumulate before being summarised and archived to RAG
AGENT_HISTORY_ARCHIVE_BATCH=10
# Max number of per-channel history summaries kept in ChromaDB (oldest pruned beyond this)
AGENT_HISTORY_MAX_SUMMARIES=100

# Logging
LOG_LEVEL=INFO

# MCP Servers (JSON array of server configs)
# MCP_SERVER_CONFIGS=[{"command": "npx", "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/files"]}]
MCP_SERVER_CONFIGS=[]

# Web UI / API
DISCORD_CLIENT_ID=your-discord-app-client-id
DISCORD_CLIENT_SECRET=your-discord-app-client-secret
DISCORD_REDIRECT_URI=http://localhost:8000/auth/discord/callback
WEB_SECRET_KEY=change-me-to-a-random-secret
WEB_CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
