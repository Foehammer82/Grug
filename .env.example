# Discord
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_PREFIX=!

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Database
DATABASE_URL=sqlite+aiosqlite:///./grug.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Scheduler
SCHEDULER_TIMEZONE=UTC

# Agent
AGENT_MAX_ITERATIONS=10
AGENT_CONTEXT_WINDOW=20

# Logging
LOG_LEVEL=INFO

# MCP Servers (JSON array of server configs)
# MCP_SERVER_CONFIGS=[{"command": "npx", "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/files"]}]
MCP_SERVER_CONFIGS=[]
